---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Página de selección de personal con Astro' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f4f7fb;
        --surface: #ffffff;
        --text: #1f2937;
        --muted: #6b7280;
        --primary: #2563eb;
        --primary-soft: #dbeafe;
        --success: #16a34a;
        --danger: #dc2626;
        --border: #e5e7eb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: linear-gradient(180deg, #eff6ff 0%, var(--bg) 20%);
        color: var(--text);
      }

      .container {
        width: min(1100px, 92%);
        margin: 0 auto;
      }

      h1,
      h2,
      h3 {
        margin: 0;
      }

      .section {
        margin-top: 2rem;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        box-shadow: 0 8px 20px rgba(31, 41, 55, 0.06);
      }

      .tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.3rem 0.65rem;
        border-radius: 999px;
      }

      .tag-ok {
        color: var(--success);
        background: #dcfce7;
      }

      .tag-warn {
        color: #b45309;
        background: #fef3c7;
      }

      .tag-bad {
        color: var(--danger);
        background: #fee2e2;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
