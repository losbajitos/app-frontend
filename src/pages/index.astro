---
import Layout from '../layouts/Layout.astro';

const candidatos = [
  {
    nombre: 'Laura Gómez',
    cargo: 'Desarrolladora Frontend Senior',
    experiencia: '7 años',
    habilidades: ['React', 'TypeScript', 'Diseño de UI'],
    estado: 'Aprobado para entrevista técnica'
  },
  {
    nombre: 'Carlos Méndez',
    cargo: 'Analista de Datos',
    experiencia: '4 años',
    habilidades: ['SQL', 'Python', 'Power BI'],
    estado: 'Pendiente de validación'
  },
  {
    nombre: 'Andrea Ruiz',
    cargo: 'Recruiter IT',
    experiencia: '6 años',
    habilidades: ['Tech Sourcing', 'Employer Branding', 'ATS'],
    estado: 'Requiere más información'
  }
];
---

<Layout title="Selección de Personal | Astro">
  <header class="hero">
    <div class="container hero-grid">
      <div>
        <p class="label">Panel de RRHH</p>
        <h1>Selección de personal</h1>
        <p class="subtitle">
          Gestiona candidatos, visualiza su estado y prioriza entrevistas en una sola página.
        </p>
      </div>
      <div class="stats card">
        <h2>Resumen rápido</h2>
        <ul>
          <li><strong>23</strong> postulaciones activas</li>
          <li><strong>8</strong> entrevistas esta semana</li>
          <li><strong>3</strong> vacantes prioritarias</li>
        </ul>
      </div>
    </div>
  </header>

  <main class="container">
    <section class="section card filters">
      <h2>Filtros</h2>
      <form>
        <label>
          Área
          <select>
            <option>Todas</option>
            <option>Tecnología</option>
            <option>Datos</option>
            <option>Recursos Humanos</option>
          </select>
        </label>
        <label>
          Seniority
          <select>
            <option>Cualquiera</option>
            <option>Junior</option>
            <option>Mid</option>
            <option>Senior</option>
          </select>
        </label>
        <label>
          Modalidad
          <select>
            <option>Todas</option>
            <option>Remoto</option>
            <option>Híbrido</option>
            <option>Presencial</option>
          </select>
        </label>
        <button type="button">Aplicar filtros</button>
      </form>
    </section>

    <section class="section">
      <h2>Candidatos destacados</h2>
      <div class="grid">
        {
          candidatos.map((candidato) => (
            <article class="card candidate">
              <div class="candidate-header">
                <div>
                  <h3>{candidato.nombre}</h3>
                  <p>{candidato.cargo}</p>
                </div>
                <span
                  class:list={[
                    'tag',
                    candidato.estado.includes('Aprobado') && 'tag-ok',
                    candidato.estado.includes('Pendiente') && 'tag-warn',
                    candidato.estado.includes('Requiere') && 'tag-bad'
                  ]}
                >
                  {candidato.estado}
                </span>
              </div>

              <p class="muted">Experiencia: {candidato.experiencia}</p>
              <ul class="skills">
                {candidato.habilidades.map((skill) => <li>{skill}</li>)}
              </ul>

              <div class="actions">
                <button class="outline" type="button">Ver perfil</button>
                <button type="button">Programar entrevista</button>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <style>
    .hero {
      padding: 3rem 0 1.5rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 1rem;
      align-items: center;
    }

    .label {
      display: inline-block;
      color: var(--primary);
      background: var(--primary-soft);
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      font-weight: 700;
      margin-bottom: 0.75rem;
      font-size: 0.85rem;
    }

    h1 {
      font-size: clamp(1.8rem, 3.5vw, 2.9rem);
      margin-bottom: 0.6rem;
    }

    .subtitle {
      color: var(--muted);
      margin: 0;
      max-width: 65ch;
    }

    .stats {
      padding: 1.2rem;
    }

    .stats h2 {
      font-size: 1.1rem;
      margin-bottom: 0.8rem;
    }

    .stats ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.5rem;
      color: var(--muted);
    }

    .stats strong {
      color: var(--text);
    }

    .filters {
      padding: 1rem;
    }

    .filters h2 {
      margin-bottom: 1rem;
      font-size: 1.1rem;
    }

    form {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.75rem;
    }

    label {
      display: grid;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--muted);
      gap: 0.4rem;
    }

    select,
    button {
      border-radius: 10px;
      border: 1px solid var(--border);
      background: white;
      min-height: 42px;
      font: inherit;
      padding: 0 0.75rem;
    }

    button {
      cursor: pointer;
      font-weight: 600;
      color: white;
      border-color: var(--primary);
      background: var(--primary);
      transition: 0.2s ease;
    }

    button:hover {
      opacity: 0.92;
      transform: translateY(-1px);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
      margin-top: 0.8rem;
    }

    .candidate {
      padding: 1rem;
    }

    .candidate-header {
      display: flex;
      gap: 0.8rem;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.75rem;
    }

    .candidate h3 {
      margin-bottom: 0.3rem;
    }

    .candidate p {
      margin: 0;
      color: var(--muted);
      font-size: 0.93rem;
    }

    .muted {
      margin: 0.85rem 0;
    }

    .skills {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }

    .skills li {
      background: #f3f4f6;
      color: #374151;
      font-size: 0.8rem;
      padding: 0.3rem 0.55rem;
      border-radius: 999px;
      font-weight: 600;
    }

    .actions {
      margin-top: 1rem;
      display: flex;
      gap: 0.5rem;
    }

    .outline {
      color: var(--primary);
      background: transparent;
    }

    @media (max-width: 980px) {
      .hero-grid {
        grid-template-columns: 1fr;
      }

      form,
      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 680px) {
      form,
      .grid {
        grid-template-columns: 1fr;
      }

      .actions {
        flex-direction: column;
      }
    }
  </style>
</Layout>
