---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Talent Match | Plataforma de empleo">
  <main class="container landing">
    <section class="card hero">
      <p class="label">Plataforma multipage</p>
      <h1>Talent Match</h1>
      <p class="subtitle">
        Portal completo para postulantes y empresas: perfiles, vacantes, búsqueda, postulaciones y ATS.
      </p>
      <div class="actions">
        <a href="/login" class="btn">Iniciar sesión</a>
        <a href="/registro" class="btn outline">Crear cuenta</a>
      </div>
    </section>
  </main>

  <style>
    .landing { min-height: 100vh; display: grid; place-items: center; padding: 2rem 0; }
    .hero { width: min(820px, 100%); padding: 2rem; text-align: center; }
    h1 { margin: 0.3rem 0 0.7rem; font-size: clamp(2rem, 5vw, 3rem); }
    .subtitle { color: var(--muted); margin: 0 0 1rem; }
    .actions { display: flex; justify-content: center; gap: 0.7rem; flex-wrap: wrap; }
    .btn { text-decoration: none; background: var(--primary); color: white; border-radius: 10px; padding: 0.7rem 1rem; font-weight: 700; border: 1px solid var(--primary); }
    .outline { background: transparent; color: var(--primary); }
  </style>
</Layout>
