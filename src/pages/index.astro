---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio | Sistema de Postulaciones">
  <main class="container landing">
    <section class="card hero">
      <p class="label">Sistema multipage</p>
      <h1>Gestión de selección de personal</h1>
      <p class="subtitle">
        Plataforma simple para registrarte, iniciar sesión y administrar postulaciones.
      </p>

      <div class="actions">
        <a class="btn" href="/login">Iniciar sesión</a>
        <a class="btn outline" href="/registro">Registrarme</a>
      </div>
    </section>
  </main>

  <style>
    .landing {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 2rem 0;
    }

    .hero {
      width: min(760px, 100%);
      padding: 2rem;
      text-align: center;
    }

    h1 {
      margin: 0.3rem 0 0.7rem;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
    }

    .subtitle {
      color: var(--muted);
      margin-top: 0;
      margin-bottom: 1.3rem;
    }

    .actions {
      display: flex;
      justify-content: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .btn {
      text-decoration: none;
      background: var(--primary);
      color: white;
      border: 1px solid var(--primary);
      border-radius: 10px;
      padding: 0.7rem 1rem;
      font-weight: 600;
    }

    .outline {
      color: var(--primary);
      background: transparent;
    }
  </style>
</Layout>
