---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro | Talent Match">
  <main class="container page">
    <section class="card block">
      <p class="label">Registro de usuario</p>
      <h1>Crear cuenta</h1>
      <form id="register-form" class="grid">
        <label>Nombre completo<input id="name" required /></label>
        <label>Email<input id="email" type="email" required /></label>
        <label>Contraseña<input id="password" type="password" minlength="6" required /></label>
        <label>Rol
          <select id="role" required>
            <option value="postulante">Postulante</option>
            <option value="empresa">Empresa</option>
          </select>
        </label>
        <button type="submit">Registrarme</button>
      </form>
      <p id="ok" class="ok" hidden>Cuenta creada. Ya puedes iniciar sesión.</p>
      <p id="error" class="error" hidden>Ese email ya está registrado.</p>
      <p class="hint">¿Ya tienes cuenta? <a href="/login">Ir a login</a></p>
    </section>
  </main>

  <script>
    const form = document.querySelector('#register-form');
    const ok = document.querySelector('#ok');
    const error = document.querySelector('#error');

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (ok instanceof HTMLElement) ok.hidden = true;
      if (error instanceof HTMLElement) error.hidden = true;

      const users = JSON.parse(localStorage.getItem('users') || '[]');
      const email = document.querySelector('#email')?.value?.trim()?.toLowerCase() || '';

      if (users.some((u) => u.email === email)) {
        if (error instanceof HTMLElement) error.hidden = false;
        return;
      }

      const user = {
        id: crypto.randomUUID(),
        name: document.querySelector('#name')?.value?.trim() || '',
        email,
        password: document.querySelector('#password')?.value || '',
        role: document.querySelector('#role')?.value || 'postulante',
        profile: {},
        companyProfile: {}
      };

      users.push(user);
      localStorage.setItem('users', JSON.stringify(users));
      if (ok instanceof HTMLElement) ok.hidden = false;
      form.reset();
    });
  </script>

  <style>
    .page { min-height: 100vh; display: grid; place-items: center; padding: 2rem 0; }
    .block { width: min(650px, 100%); padding: 1.5rem; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 0.8rem; margin-top: 1rem; }
    label { display: grid; gap: 0.3rem; color: var(--muted); font-weight: 600; }
    input, select, button { min-height: 42px; border: 1px solid var(--border); border-radius: 10px; padding: 0 0.75rem; font: inherit; }
    button { grid-column: 1/-1; background: var(--primary); color: white; border-color: var(--primary); font-weight: 700; }
    .ok { color: var(--success); font-weight: 700; }
    .error { color: var(--danger); font-weight: 700; }
    .hint { color: var(--muted); }
    a { color: var(--primary); }
    @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }
  </style>
</Layout>
