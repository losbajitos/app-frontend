---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro | Sistema de Postulaciones">
  <main class="container auth-wrapper">
    <section class="card auth-card">
      <p class="label">Nuevo usuario</p>
      <h1>Registrarse</h1>
      <p class="subtitle">Crea tu cuenta para ingresar al sistema.</p>

      <form id="register-form" class="form-grid">
        <label>
          Usuario
          <input id="new-username" type="text" required />
        </label>

        <label>
          Clave
          <input id="new-password" type="password" minlength="4" required />
        </label>

        <button type="submit">Crear cuenta</button>
      </form>

      <p id="register-ok" class="ok" hidden>Cuenta creada. Ahora puedes iniciar sesión.</p>
      <p id="register-error" class="error" hidden>El usuario ya existe.</p>
      <p class="hint">¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>.</p>
    </section>
  </main>

  <script>
    const form = document.querySelector('#register-form');
    const ok = document.querySelector('#register-ok');
    const error = document.querySelector('#register-error');

    const getUsers = () => {
      const stored = localStorage.getItem('users');
      return stored ? JSON.parse(stored) : [];
    };

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (ok instanceof HTMLElement) ok.hidden = true;
      if (error instanceof HTMLElement) error.hidden = true;

      const username = document.querySelector('#new-username')?.value?.trim() || '';
      const password = document.querySelector('#new-password')?.value || '';
      const users = getUsers();

      const exists = username === 'admin' || users.some((u) => u.username === username);
      if (exists) {
        if (error instanceof HTMLElement) error.hidden = false;
        return;
      }

      users.push({ username, password });
      localStorage.setItem('users', JSON.stringify(users));
      if (ok instanceof HTMLElement) ok.hidden = false;
      form.reset();
    });
  </script>

  <style>
    .auth-wrapper { min-height: 100vh; display: grid; place-items: center; padding: 2rem 0; }
    .auth-card { width: min(520px, 100%); padding: 1.5rem; }
    .subtitle, .hint { color: var(--muted); margin-top: 0; }
    .form-grid { display: grid; gap: 0.8rem; margin-top: 1rem; }
    label { display: grid; gap: 0.35rem; font-size: 0.92rem; font-weight: 600; color: var(--muted); }
    input, button { min-height: 42px; border-radius: 10px; border: 1px solid var(--border); padding: 0 0.75rem; font: inherit; }
    button { background: var(--primary); color: white; border-color: var(--primary); font-weight: 600; cursor: pointer; }
    .error { color: var(--danger); font-weight: 600; }
    .ok { color: var(--success); font-weight: 600; }
    a { color: var(--primary); }
  </style>
</Layout>
